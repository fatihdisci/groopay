{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      },
      "channel": "development"
    },
    "development:ios": {
      "extends": "development",
      "ios": {
        "simulator": false
      },
      "channel": "development:ios"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "env": {
        "APP_VARIANT": "production"
      },
      "autoIncrement": true
    },
    "production:ios": {
      "extends": "production",
      "ios": {
        "image": "latest"
      },
      "channel": "production:ios"
    },
    "production:android": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production:android"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "av.fatihdisci@gmail.com",
        "ascAppId": "6776313459",
        "appleTeamId": "8XPP7Z37GF"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
